# Скопируйте в .env для `vercel dev` ИЛИ только Vercel → Project → Settings → Environment Variables
# Никогда не коммитьте .env и не вставляйте токен в код.

# Токен бота (любое имя — поддерживаются оба):
TELEGRAM_BOT_TOKEN=123456789:AA...your_token_from_BotFather
# TELEGRAM_BOT_API=123456789:AA...   # альтернативное имя переменной

# Куда слать заявки: ваш числовой chat_id (напишите боту @userinfobot) или id группы с ботом
TELEGRAM_CHAT_ID=-1001234567890
